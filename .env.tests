# Colissimo
URL_API_CARRIER_COLISSIMO=https://api.laposte.fr/colissimo/v1/shipping
COLISSIMO_API_KEY=ta_clé_api_colissimo

# FedEx
URL_API_CARRIER_FEDEX=https://apis-sandbox.fedex.com
FEDEX_CLIENT_ID=ton_id_client_fedex
FEDEX_CLIENT_SECRET=ton_code_client_secret_fedex
FEDEX_ACCOUNT_NUMBER=ton_numero_de_compte_fedex

# TNT
URL_API_CARRIER_TNT=https://api.tnt.com/expressconnect
TNT_API_KEY=ta_clé_api_tnt
TNT_ACCOUNT_NUMBER=ton_numero_de_compte_tnt

# UPS
URL_API_CARRIER_UPS=https://onlinetools.ups.com
UPS_CLIENT_ID=ton_id_client_ups
UPS_CLIENT_SECRET=ton_code_client_secret_ups
UPS_ACCOUNT_NUMBER=ton_numero_de_compte_ups

# Chronopost
URL_API_CARRIER_CHRONOPOST=https://api.chronopost.fr
CHRONOPOST_ACCOUNT_NUMBER=ton_numero_de_compte_chronopost
